{
  "name": "voidrp-electron-bridge",
  "version": "2.1.0",
  "description": "VoidRP Launcher strategic migration: Electron + Vue UI with embedded C# launcher core",
  "main": "dist-electron/main.js",
  "author": "OpenAI for VoidRP",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build:core:dev": "dotnet build ./core/VoidRpLauncher.CoreHost/VoidRpLauncher.CoreHost.csproj -c Debug",
    "build:electron": "tsc -p tsconfig.node.json && node ./scripts/fix-electron-build.mjs",
    "dev:electron": "npm run build:core:dev && npm run build:electron && wait-on http://127.0.0.1:5173 && electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "vite build",
    "build": "npm run build:core:dev && npm run build:electron && npm run build:renderer"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "pinia": "^2.3.1",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.7.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "daisyui": "^5.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.8",
    "vue-tsc": "^3.0.7",
    "wait-on": "^8.0.5"
  }
}
